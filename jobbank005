<!DOCTYPE html>
<html lang="si">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SL Job Bank</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:'Poppins',sans-serif;
    }

    body{
      background:#f4f7fb;
      color:#222;
      line-height:1.6;
    }

    header{
      background:linear-gradient(135deg,#0f172a,#1e3a8a);
      color:white;
      padding:20px 8%;
      display:flex;
      justify-content:space-between;
      align-items:center;
      position:sticky;
      top:0;
      z-index:1000;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
    }

    .logo{
      font-size:28px;
      font-weight:700;
    }

    nav a{
      color:white;
      text-decoration:none;
      margin-left:25px;
      font-weight:500;
      transition:0.3s;
    }

    nav a:hover{
      color:#60a5fa;
    }

    .hero{
      min-height:90vh;
      display:flex;
      align-items:center;
      justify-content:center;
      text-align:center;
      padding:60px 8%;
      background:linear-gradient(rgba(15,23,42,0.8),rgba(30,58,138,0.8)), url('https://images.unsplash.com/photo-1521791136064-7986c2920216?q=80&w=1200&auto=format&fit=crop') center/cover;
      color:white;
    }

    .hero-content{
      max-width:800px;
    }

    .hero h1{
      font-size:55px;
      margin-bottom:20px;
      line-height:1.2;
    }

    .hero p{
      font-size:18px;
      margin-bottom:30px;
      opacity:0.95;
    }

    .btn{
      display:inline-block;
      background:#2563eb;
      color:white;
      padding:14px 30px;
      border-radius:10px;
      text-decoration:none;
      font-weight:600;
      transition:0.3s;
    }

    .btn:hover{
      background:#1d4ed8;
      transform:translateY(-2px);
    }

    .section{
      padding:80px 8%;
    }

    .section-title{
      text-align:center;
      margin-bottom:50px;
    }

    .section-title h2{
      font-size:38px;
      color:#0f172a;
      margin-bottom:10px;
    }

    .jobs{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:25px;
    }

    .job-card{
      background:white;
      padding:25px;
      border-radius:18px;
      box-shadow:0 10px 25px rgba(0,0,0,0.08);
      transition:0.3s;
      border:1px solid #e5e7eb;
    }

    .job-card:hover{
      transform:translateY(-5px);
    }

    .job-card h3{
      margin-bottom:10px;
      color:#1e3a8a;
    }

    .job-card p{
      color:#555;
      margin-bottom:10px;
      font-size:14px;
    }

    .salary{
      font-weight:600;
      color:#16a34a;
      margin-bottom:15px;
      display:block;
    }

    .apply-btn{
      display:inline-block;
      background:#0f172a;
      color:white;
      padding:10px 20px;
      border-radius:8px;
      text-decoration:none;
      transition:0.3s;
    }

    .apply-btn:hover{
      background:#1e293b;
    }

    .upload-section{
      background:white;
      border-radius:20px;
      padding:40px;
      box-shadow:0 10px 25px rgba(0,0,0,0.08);
      max-width:800px;
      margin:auto;
    }

    form{
      display:grid;
      gap:20px;
    }

    input, textarea, select{
      width:100%;
      padding:14px;
      border:1px solid #d1d5db;
      border-radius:10px;
      font-size:15px;
    }

    textarea{
      resize:none;
      height:130px;
    }

    button{
      border:none;
      cursor:pointer;
    }

    .adsense-box{
      background:#eef2ff;
      border:2px dashed #4f46e5;
      padding:30px;
      text-align:center;
      border-radius:15px;
      margin-top:50px;
      color:#1e1b4b;
    }

    footer{
      background:#0f172a;
      color:white;
      text-align:center;
      padding:25px;
      margin-top:60px;
    }

    @media(max-width:768px){
      .hero h1{
        font-size:38px;
      }

      header{
        flex-direction:column;
        gap:15px;
      }

      nav a{
        margin:0 10px;
      }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo">SL Job Bank</div>

    <nav>
      <a href="#home">Home</a>
      <a href="#jobs">Jobs</a>
      <a href="#upload">Upload Job</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section class="hero" id="home">
    <div class="hero-content">
      <h1>Sri Lanka Job Bank Website</h1>
      <p>
        ලංකාවේ අලුත්ම ජොබ්, Government Jobs, Private Jobs සහ Foreign Jobs 
        එකම තැනකින් බලන්න. දවසින් දවස නව ජොබ් දමන්න සහ Applications Upload කරන්න.
      </p>

      <a href="#jobs" class="btn">View Latest Jobs</a>
    </div>
  </section>

  <section class="section" id="jobs">
    <div class="section-title">
      <h2>Latest Job Vacancies</h2>
      <p>Updated Daily</p>
    </div>

    <div class="jobs">

      <div class="job-card">
        <h3>Graphic Designer</h3>
        <p>Company: ABC Solutions</p>
        <p>Location: Colombo</p>
        <span class="salary">Salary: Rs. 80,000</span>
        <a href="#upload" class="apply-btn">Apply Now</a>
      </div>

      <div class="job-card">
        <h3>Software Developer</h3>
        <p>Company: Tech Lanka</p>
        <p>Location: Kandy</p>
        <span class="salary">Salary: Rs. 150,000</span>
        <a href="#upload" class="apply-btn">Apply Now</a>
      </div>

      <div class="job-card">
        <h3>Office Assistant</h3>
        <p>Company: Smart Holdings</p>
        <p>Location: Gampaha</p>
        <span class="salary">Salary: Rs. 55,000</span>
        <a href="#upload" class="apply-btn">Apply Now</a>
      </div>

      <div class="job-card">
        <h3>Video Editor</h3>
        <p>Company: Media House</p>
        <p>Location: Negombo</p>
        <span class="salary">Salary: Rs. 90,000</span>
        <a href="#upload" class="apply-btn">Apply Now</a>
      </div>

    </div>

    <div class="adsense-box">
      <h3>Google AdSense Ad Space</h3>
      <p>
        මෙතනට ඔබගේ Google AdSense Code එක Paste කරන්න.
      </p>
    </div>
  </section>

  <section class="section" id="upload">
    <div class="section-title">
      <h2>Admin Job Management</h2>
      <p>Only website owner can update jobs</p>
    </div>

    <div class="upload-section">
      <form>
        <input type="text" placeholder="Enter Job Title" required>

        <input type="text" placeholder="Company Name" required>

        <select>
          <option>Select Category</option>
          <option>Government Jobs</option>
          <option>Private Jobs</option>
          <option>Foreign Jobs</option>
          <option>Bank Jobs</option>
          <option>IT Jobs</option>
        </select>

        <textarea placeholder="Type full job details here"></textarea>

        <input type="file">

        <button class="btn">Publish Job Post</button>
      </form>
    </div>

    <div class="adsense-box">
      <h3>Professional Job Portal</h3>
      <p>
        Visitors can only view jobs beautifully. 
        Only you can upload and manage jobs from admin side.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-title">
      <h2>Why This Website Looks Professional</h2>
    </div>

    <div class="jobs">
      <div class="job-card">
        <h3>Clean Modern Design</h3>
        <p>
          Simple professional layout that looks like a real Sri Lankan job website.
        </p>
      </div>

      <div class="job-card">
        <h3>Owner Controlled</h3>
        <p>
          Visitors cannot upload jobs. Only you update daily job vacancies.
        </p>
      </div>

      <div class="job-card">
        <h3>AdSense Friendly</h3>
        <p>
          Clean structure suitable for Google AdSense approval.
        </p>
      </div>
    </div>
  </section>

  <footer id="contact">
    <p>© 2026 SL Job Bank | Designed for AdSense Ready Job Website</p>
  </footer>

</body>
</html>
